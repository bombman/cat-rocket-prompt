# Ghostty Optimized Config
# ------------------------

# Font: Nerd Font is required for the icons
font-family = "JetBrainsMono Nerd Font"
font-size = 12

# Cursor
cursor-style = bar
shell-integration-features = no-cursor

# Window Decoration (Draggable Title Bar)
window-decoration = true
background-opacity = 1.0
window-padding-x = 10
window-padding-y = 10

# Practical Dev Features
copy-on-select = true